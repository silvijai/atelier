{
  "title": "Caps Lock: Hyper (hold), F20 (tap), Normal Caps (Fn+tap)",
  "rules": [
    {
      "description": "Caps Lock Behavior Logic",
      "manipulators": [
        {
          "description": "Fn + Caps Lock -> Standard Caps Lock",
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "mandatory": ["fn"],
              "optional": ["any"]
            }
          },
          "to": [{ "key_code": "caps_lock" }]
        },
        {
          "description": "Caps Lock -> Hyper Key (hold) / F20 (tap)",
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_shift",
              "modifiers": [
                "left_command",
                "left_control",
                "left_option"
              ]
            }
          ],
          "to_if_alone": [{ "key_code": "f20" }]
        }
      ]
    }
  ]
}
